{
  "name": "node_project",
  "version": "1.0.0",
  "description": "",
  "main": "dist/app.js",
  "engines": {
    "node": "22.*"
  },
  "scripts": {
    "unit": "./node_modules/.bin/jest --testPathPatterns=tests/unit --coverage",
    "build": "./node_modules/.bin/tsc",
    "start": "NODE_ENV=production node build/src/Index.js",
    "start:ci": "(npm run start:dynamodblocal && npm run mocks) > logs.txt 2>&1 & node --env-file='.env' build/src/Index.js",
    "start:dynamodblocal": "./scripts/setup-dynamodb-local.sh",
    "kill:dynamodblocal": "./scripts/kill-dynamodb-local.sh",
    "mocks": "npx wiremock --port 8030 --root-dir test/mocks",
    "test": "npm run build && npm run unit",
    "lint": "eslint --output-file ./reports/eslint/reportFile.html --format html -c eslint.config.mjs",
    "lint:fix": "eslint --fix --output-file ./reports/eslint/report.html --format html -c .eslintrc.js --ext .ts .",
    "prettier": "prettier \"**/*.{js,md}\" --check",
    "prettier:fix": "npm prettier --write",
    "test:ipvr": "bash ./checkIpvResume.sh",
    "test:browser": "wait-on tcp:127.0.0.1:8080 && wait-on tcp:127.0.0.1:8000 && wait-on tcp:127.0.0.1:8030 && cucumber-js test/browser/features/**/*.feature --require test/browser/step_definitions/**/*.js --require test/browser/support/setup.js -f json:./test/reports/cucumber_report.json --tags @browser",
    "test:browser:ci": "npm run start:ci & npm run test:browser && kill $!",
    "test:e2e:cd:cucumber": "wait-on && cucumber-js test/browser/features/**/*.feature --require test/browser/step_definitions/**/*.js --require test/browser/support/setup.js -f json:./test/reports/cucumber_report.json --tags \"@e2e or @browser\"",
    "test:e2e:cd": "npm run test:e2e:cd:cucumber",
    "test:pii": "bash ./check-logs.sh",
    "test:e2e": "cucumber-js test/browser/features/**/*.feature --require test/browser/step_definitions/**/*.js -f json:./test/reports/cucumber_report.json --tags @e2e"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@aws-sdk/client-ssm": "3.1045.0",
    "@cucumber/cucumber": "12.7.0",
    "@eslint/eslintrc": "3.3.4",
    "@eslint/js": "9.39.2",
    "@types/chai": "5.2.3",
    "@types/express": "4.17.23",
    "@types/jest": "29.5.14",
    "@types/mocha": "10.0.10",
    "@types/proxyquire": "1.3.31",
    "@types/sinon": "^1.0.1",
    "@types/sinon-chai": "4.0.0",
    "chai": "6.2.2",
    "chai-as-promised": "8.0.2",
    "dotenv": "17.4.2",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "15.15.0",
    "jest": "30.2.0",
    "jest-mock-extended": "4.0.0",
    "multiple-cucumber-html-reporter": "3.10.0",
    "playwright": "1.58.2",
    "prettier": "3.8.1",
    "sinon": "22.0.0",
    "sinon-chai": "4.0.1",
    "supertest": "7.2.2",
    "ts-jest": "29.4.1",
    "ts-node": "10.9.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.56.1",
    "wait-on": "9.0.10",
    "wiremock": "3.13.2"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "3.1001.0",
    "@aws-sdk/lib-dynamodb": "3.1045.0",
    "@govuk-one-login/frontend-passthrough-headers": "1.3.2",
    "axios": "1.16.0",
    "express": "4.22.1",
    "winston": "3.17.0"
  },
  "overrides": {
    "form-data": "4.0.4"
  }
}
